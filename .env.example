# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_TOKEN=你的Telegram-Bot-Token

# HKBU GenAI API（从 https://genai.hkbu.edu.hk 登录后获取）
HKBU_API_KEY=你的HKBU-GenAI-API-Key
HKBU_BASE_URL=https://genai.hkbu.edu.hk/general/rest
HKBU_MODEL_NAME=gpt-4o-mini
HKBU_API_VERSION=2024-12-01-preview

# AWS RDS PostgreSQL 数据库
DB_HOST=你的RDS-Endpoint.ap-southeast-1.rds.amazonaws.com
DB_NAME=chatbot_db
DB_USER=chatbot_user
DB_PASSWORD=你的数据库密码
DB_PORT=5432
